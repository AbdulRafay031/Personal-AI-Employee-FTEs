# --- AI Model (Choose ONE) ---

# Option A: OpenRouter (Free Tier)
# 1. Go to https://openrouter.ai/
# 2. Create account with rafay16031@gmail.com
# 3. Get free API key
# 4. Paste below:
OPENROUTER_API_KEY=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
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
QWEN_MODEL=qwen/qwen-2.5-coder-32b-instruct

# Option B: Local Ollama (Uncomment if using local AI)
# 1. Download from https://ollama.ai/
# 2. Run: ollama pull qwen2.5-coder
# 3. Uncomment these lines:
# OPENROUTER_API_KEY=local
# QWEN_MODEL=ollama/qwen2.5-coder

# --- Gmail Configuration ---
# Method 1: SMTP (Easier - Recommended)
# 1. Enable 2FA on Google Account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Create app password for "Mail"
# 4. Paste below:
GMAIL_SMTP_SERVER=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_USER=rafay16031@gmail.com
GMAIL_APP_PASSWORD=qhgv ghky tzka rldc

# Method 2: Gmail API (More features, more setup)
# GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GMAIL_CLIENT_SECRET=your-client-secret
# GMAIL_REDIRECT_URI=http://localhost:8080/callback
# GMAIL_CREDENTIALS_PATH=/full/path/to/credentials.json
# GMAIL_TOKEN_PATH=/full/path/to/AI_Employee_Vault/.gmail_token.json

# --- WhatsApp Configuration ---
# Session will be stored in vault (add to .gitignore!)
WHATSAPP_SESSION_PATH=AI_Employee_Vault/.whatsapp_session

# Keywords that trigger notifications (comma-separated)
WHATSAPP_KEYWORDS=urgent,asap,invoice,payment,help,quote,pricing,emergency

# --- LinkedIn Configuration ---
# Session will be stored in vault (add to .gitignore!)
LINKEDIN_SESSION_PATH=AI_Employee_Vault/.linkedin_session

# Preferred posting time (24-hour format)
LINKEDIN_POSTING_TIME=09:00

# --- Vault Configuration ---
# Use full absolute path
VAULT_PATH=C:/Users/Noman Traders/Documents/GitHub/Personal-AI-Employee-FTEs/AI_Employee_Vault

# --- Safety Settings ---
# DRY_RUN=true means AI will log but NOT execute actions
DRY_RUN=false

# Maximum emails AI can send per day (0 = unlimited)
MAX_EMAILS_PER_DAY=50

# Require human approval for sensitive actions
REQUIRE_APPROVAL=true

# --- Approval Thresholds ---
# Payments under this amount can be auto-approved to known vendors
AUTO_APPROVE_PAYMENT_UNDER=5000

# Currency (for display only)
CURRENCY=PKR

# --- Notification Settings ---
# Send WhatsApp notification for high-priority items
WHATSAPP_NOTIFY=true

# Your WhatsApp number (for notifications)
# Format: with country code, no + sign (e.g., 923161163799 for Pakistan)
YOUR_WHATSAPP_NUMBER=923161163799

# --- Logging ---
LOG_LEVEL=INFO

# --- Orchestrator Settings ---
# How often to check for new tasks (seconds)
ORCHESTRATOR_INTERVAL=60

# --- Advanced Settings ---
# Site URL for OpenRouter (optional)
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=AI Employee FTE
