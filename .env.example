# AI Employee FTE - Environment Variables
# Copy this file to .env and fill in your actual values

# OpenRouter API Configuration
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=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

# OpenRouter API Base URL (default)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Qwen Model to use
# Available models: https://openrouter.ai/models?q=qwen
QWEN_MODEL=qwen/qwen-2.5-coder-32b-instruct

# Optional: Site URL for OpenRouter ranking (your website)
OPENROUTER_SITE_URL=

# Optional: App name for OpenRouter
OPENROUTER_APP_NAME=AI Employee FTE

# Gmail API Credentials (optional - for Gmail watcher)
GMAIL_CREDENTIALS_PATH=credentials.json

# Dry Run Mode (set to 'true' to prevent real actions)
DRY_RUN=false
